# =============================================================================
# ReviewRadar — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma ORM.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local dev: use a local Postgres instance or a free tier on Supabase/Neon.
# Production: use a managed Postgres service (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/reviewradar?schema=public"

# Direct (non-pooled) connection URL — required for Prisma migrations on Supabase/Neon.
# Same format as DATABASE_URL but bypasses the connection pooler.
# Optional for local dev; required for production on pooled environments.
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/reviewradar?schema=public"

# -----------------------------------------------------------------------------
# NEXT-AUTH (Authentication)
# -----------------------------------------------------------------------------

# A random secret used to sign/encrypt NextAuth.js JWT tokens and cookies.
# Generate with: openssl rand -base64 32
# Required in all environments.
NEXTAUTH_SECRET="your-nextauth-secret-here"

# The canonical URL of your app — used by NextAuth.js for OAuth redirects.
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth credentials for social sign-in.
# Obtain from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorised redirect URI must include: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth credentials (optional social sign-in).
# Obtain from: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# -----------------------------------------------------------------------------
# STRIPE (Billing & Payments)
# -----------------------------------------------------------------------------

# Stripe secret key — used server-side only for API calls (charges, customers, etc.)
# Test keys start with sk_test_, live keys with sk_live_
# Obtain from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"

# Stripe publishable key — safe to expose client-side.
# Test keys start with pk_test_, live keys with pk_live_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"

# Stripe webhook signing secret — used to verify webhook payloads.
# Obtain from: https://dashboard.stripe.com/webhooks → select endpoint → Signing secret
# For local testing use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret_here"

# Stripe Price IDs for subscription tiers.
# Obtain from: https://dashboard.stripe.com/products → select product → price ID
# Format: price_XXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_STARTER="price_your_starter_price_id_here"
STRIPE_PRICE_GROWTH="price_your_growth_price_id_here"

# -----------------------------------------------------------------------------
# OPENAI (AI Response Drafting)
# -----------------------------------------------------------------------------

# OpenAI API key — used server-side to generate AI-drafted review responses.
# Obtain from: https://platform.openai.com/api-keys
# Format: sk-proj-... (newer) or sk-... (legacy)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# OpenAI model to use for response generation.
# Recommended: gpt-4o (best quality) or gpt-3.5-turbo (lower cost)
# See: https://platform.openai.com/docs/models
OPENAI_MODEL="gpt-4o"

# -----------------------------------------------------------------------------
# GOOGLE BUSINESS PROFILE API (Review Integration)
# -----------------------------------------------------------------------------

# Google Business Profile OAuth 2.0 client credentials.
# Obtain from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Required scopes: https://www.googleapis.com/auth/business.manage
GOOGLE_BUSINESS_CLIENT_ID="your-google-business-client-id"
GOOGLE_BUSINESS_CLIENT_SECRET="your-google-business-client-secret"

# -----------------------------------------------------------------------------
# TRUSTPILOT API (Review Integration)
# -----------------------------------------------------------------------------

# Trustpilot Business API key.
# Obtain from: https://developers.trustpilot.com/ → Create application
TRUSTPILOT_API_KEY="your-trustpilot-api-key"
TRUSTPILOT_API_SECRET="your-trustpilot-api-secret"

# -----------------------------------------------------------------------------
# YELP FUSION API (Review Integration)
# -----------------------------------------------------------------------------

# Yelp Fusion API key for fetching business reviews.
# Obtain from: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY="your-yelp-fusion-api-key"

# -----------------------------------------------------------------------------
# APPLICATION CONFIG
# -----------------------------------------------------------------------------

# Base URL of the application — used for generating absolute links in emails/webhooks.
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Application environment — affects logging, error handling, and feature flags.
# Values: development | staging | production
NODE_ENV="development"

# -----------------------------------------------------------------------------
# EMAIL (Transactional)
# -----------------------------------------------------------------------------

# SMTP connection URL for sending transactional emails (alerts, digests, auth).
# Format: smtp://USER:PASSWORD@HOST:PORT
# Providers: Resend, Postmark, SendGrid, Mailgun, AWS SES
# For Resend: use their SMTP credentials or Resend SDK with RESEND_API_KEY
SMTP_URL="smtp://user:password@smtp.provider.com:587"

# Sender email address shown in the From field.
EMAIL_FROM="noreply@yourdomain.com"

# Resend API key (alternative to SMTP — if using Resend SDK directly).
# Obtain from: https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key_here"

# -----------------------------------------------------------------------------
# REDIS (Optional — Rate Limiting / Caching)
# -----------------------------------------------------------------------------

# Redis connection URL for persistent rate limiting or caching.
# Format: redis://[:PASSWORD@]HOST:PORT[/DB]
# Local: redis://localhost:6379
# Cloud: Upstash Redis (https://upstash.com/)
REDIS_URL="redis://localhost:6379"

# Upstash Redis REST credentials (if using Upstash HTTP client instead of redis://).
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"
