generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum ReviewSource {
  GOOGLE
  YELP
  TRIPADVISOR
  FACEBOOK
  TRUSTPILOT
  CUSTOM
}

enum AlertType {
  NEGATIVE_REVIEW
  POSITIVE_REVIEW
  RATING_DROP
  NEW_REVIEW
  SENTIMENT_CHANGE
  WEEKLY_DIGEST
}

enum AlertChannel {
  EMAIL
  SMS
  WEBHOOK
  SLACK
}

enum IntegrationType {
  GOOGLE_MY_BUSINESS
  YELP
  TRIPADVISOR
  FACEBOOK
  TRUSTPILOT
  SLACK
  WEBHOOK
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  businesses     Business[]
  alerts        Alert[]
  integrations  Integration[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model Business {
  id          String   @id @default(cuid())
  userId      String
  name        String
  address     String?
  city        String?
  state       String?
  country     String   @default("US")
  postalCode  String?
  phone       String?
  website     String?
  placeId     String?
  latitude    Float?
  longitude   Float?
  avgRating   Float    @default(0)
  totalReviews Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews        Review[]
  alerts         Alert[]
  integrations   Integration[]
  sentimentScores SentimentScore[]

  @@index([userId])
  @@index([placeId])
}

model Review {
  id             String       @id @default(cuid())
  businessId     String
  source         ReviewSource
  externalId     String?
  authorName     String?
  authorImage    String?
  rating         Float
  title          String?
  body           String?      @db.Text
  language       String       @default("en")
  isVerified     Boolean      @default(false)
  isReplied      Boolean      @default(false)
  replyText      String?      @db.Text
  replyDate      DateTime?
  publishedAt    DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sentimentScore SentimentScore?

  @@unique([businessId, source, externalId])
  @@index([businessId])
  @@index([publishedAt])
  @@index([rating])
  @@index([source])
}

model SentimentScore {
  id               String   @id @default(cuid())
  reviewId         String?  @unique
  businessId       String
  score            Float
  magnitude        Float    @default(0)
  label            String
  positiveAspects  String[] @default([])
  negativeAspects  String[] @default([])
  keywords         String[] @default([])
  summary          String?  @db.Text
  modelVersion     String   @default("gpt-4")
  analyzedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  review   Review?  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([score])
  @@index([analyzedAt])
}

model Alert {
  id          String       @id @default(cuid())
  userId      String
  businessId  String?
  type        AlertType
  channel     AlertChannel @default(EMAIL)
  name        String
  isActive    Boolean      @default(true)
  threshold   Float?
  webhookUrl  String?
  slackChannel String?
  phoneNumber String?
  emailTo     String?
  conditions  Json         @default("{}")
  lastFiredAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([businessId])
  @@index([isActive])
}

model Integration {
  id           String          @id @default(cuid())
  userId       String
  businessId   String?
  type         IntegrationType
  name         String
  accessToken  String?         @db.Text
  refreshToken String?         @db.Text
  tokenExpiry  DateTime?
  accountId    String?
  config       Json            @default("{}")
  isActive     Boolean         @default(true)
  lastSyncAt   DateTime?
  syncFrequency Int            @default(60)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@unique([userId, businessId, type])
  @@index([userId])
  @@index([businessId])
  @@index([isActive])
}
